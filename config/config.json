

{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx-build/config.2.0.schema.json",
  "version": "2.0",
  "bundles": {
    "learning-center-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/learningCenter/LearningCenterWebPart.js",
          "manifest": "./src/webparts/learningCenter/LearningCenterWebPart.manifest.json"
